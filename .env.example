# Copy this file to .env for local development and fill in real values.
# In production (Render), set these as Environment Variables in the dashboard —
# do not commit a real .env file.

# Django
# Generate a new one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-this-is-my-secret-key-for-local-development
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (Render provides this automatically when you attach a Postgres
# instance; for local dev you can leave it unset to fall back to SQLite)
DATABASE_URL=

# AI Assistant feature (vault/ai_service.py). Optional — if unset, the
# AI assistant feature degrades gracefully rather than erroring.
ANTHROPIC_API_KEY=

# Security (set to True once HTTPS is confirmed working on your domain)
SECURE_SSL_REDIRECT=True
